# Copy this file to .env and fill in your real values.
# Get these from your Aiven MySQL service overview page.

DB_HOST=your-service-name.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=your-password-here
DB_NAME=defaultdb

# If Aiven gives you a CA certificate file (ca.pem), place it in this folder
# and keep this path as-is. If you don't have one yet, leave it — the app
# will try connecting with SSL required but no CA verification, which works
# for most Aiven free-tier setups. See README.md for details.
DB_SSL_CA=ca.pem

# Port the Flask server runs on locally / in Replit
PORT=8000
